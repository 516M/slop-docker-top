#!/usr/bin/env bash
# docker-top - container monitor TUI (dual-mode launcher)
# Uses nix-shell on NixOS, falls back to system python3 on other distros.

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
    DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
SCRIPT="$DIR/docker-top.py"

if ! [ -f "$SCRIPT" ]; then
    echo "ERROR: $SCRIPT not found" >&2
    exit 1
fi

if command -v nix-shell &>/dev/null; then
    exec nix-shell -p python3 --run "python3 $(printf '%q ' "$SCRIPT" "$@")"
fi

exec python3 "$SCRIPT" "$@"
